---
import Base from '../layouts/Base.astro';

const listingURL = 'https://theabacoclub.com/rentals/cabana-112/';

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LodgingBusiness",
      "name": "Cabana 112 at The Abaco Club",
      "description": "A private, freestanding octagonal cabana at The Abaco Club on Winding Bay, Abaco, Bahamas. Steps from two miles of white-sand beach, set along the first fairway of the #1 golf course in the Bahamas.",
      "url": listingURL,
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Marsh Harbour",
        "addressRegion": "Abaco",
        "addressCountry": "BS"
      },
      "numberOfRooms": "1",
      "amenityFeature": [
        { "@type": "LocationFeatureSpecification", "name": "Beachfront access", "value": true },
        { "@type": "LocationFeatureSpecification", "name": "Golf course view", "value": true },
        { "@type": "LocationFeatureSpecification", "name": "Full kitchen", "value": true },
        { "@type": "LocationFeatureSpecification", "name": "Rainfall shower", "value": true },
        { "@type": "LocationFeatureSpecification", "name": "Sunroom", "value": true }
      ],
      "priceRange": "$899–$1,100 per night",
      "image": "https://theabacoclub.com/wp-content/uploads/2024/10/DJI_20241014103859_0246_D.jpg"
    },
    {
      "@type": "WebSite",
      "name": "Cabana 112 Abaco",
      "url": "https://cabana112abaco.com"
    }
  ]
};
---

<Base
  title="Private Cabana Rental in the Bahamas"
  description="Cabana 112 at The Abaco Club — a serene one-bedroom private retreat on Winding Bay, Abaco. Steps from 2 miles of white-sand beach, with golf course views and a spa-style rainfall shower."
  canonicalURL="/"
  structuredData={structuredData}
>
  <style>
    .hero {
      color: #fff;
      padding: 4rem 1.5rem;
      text-align: center;
      background-color: var(--navy);
      background-image: linear-gradient(
          rgba(18, 73, 106, 0.58),
          rgba(18, 73, 106, 0.78)
        ),
        url('/images/cabanas.jpg');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    }

    .hero h2 {
      font-size: clamp(1.65rem, 4vw, 2.35rem);
      font-weight: 400;
      line-height: 1.2;
      max-width: 700px;
      margin: 0 auto 1.5rem;
      letter-spacing: 0.02em;
      text-align: center;
    }

    .hero p {
      font-family: sans-serif;
      font-size: 1rem;
      color: #fff;
      max-width: 640px;
      margin: 0 auto 1.25rem;
      line-height: 1.75;
    }

    .hero p:last-of-type {
      margin-bottom: 0;
    }

    .access {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 2rem 1.5rem 3.5rem;
      text-align: center;
    }

    .access h2 {
      font-size: 1.6rem;
      font-weight: 400;
      color: var(--navy);
      margin-bottom: 1.25rem;
      letter-spacing: 0.02em;
      text-align: center;
    }

    .access p {
      font-family: sans-serif;
      font-size: 0.95rem;
      color: var(--muted);
      line-height: 1.85;
      margin: 0;
    }

    .features {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 3.5rem 1.5rem 2.5rem;
    }

    .features-heading {
      font-size: 1.6rem;
      font-weight: 400;
      color: var(--navy);
      margin-bottom: 2.5rem;
      letter-spacing: 0.02em;
      text-align: center;
    }

    .features-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem 2.25rem;
    }

    @media (max-width: 640px) {
      .features-grid {
        grid-template-columns: 1fr;
      }
    }

    .feature {
      background: #fff;
      border: 1px solid var(--border);
      padding: 1.85rem 1.65rem;
      box-shadow: 0 2px 14px rgba(18, 73, 106, 0.07);
    }

    .feature h3 {
      font-size: 1.08rem;
      font-weight: 400;
      color: var(--navy);
      margin-bottom: 0.75rem;
      letter-spacing: 0.02em;
      line-height: 1.35;
    }

    .feature p {
      font-family: sans-serif;
      font-size: 0.9rem;
      color: var(--muted);
      line-height: 1.75;
      margin: 0;
    }

    .feature .icon {
      font-size: 1.65rem;
      margin-bottom: 1rem;
      display: block;
    }

    .divider { border: none; border-top: 1px solid var(--border); margin: 0 1.5rem; }

    .rates {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 3.5rem 1.5rem;
      text-align: center;
    }

    .rates h2 {
      font-size: 1.6rem;
      font-weight: 400;
      color: var(--navy);
      margin-bottom: 1.25rem;
      letter-spacing: 0.02em;
      text-align: center;
    }

    .rates p {
      font-family: sans-serif;
      font-size: 0.95rem;
      color: var(--muted);
      line-height: 1.85;
      margin-bottom: 1rem;
    }

    .rates p:last-child {
      margin-bottom: 0;
    }

    .rates .price {
      font-size: 1.2rem;
      font-weight: 600;
      color: var(--navy);
      letter-spacing: 0.02em;
    }

  </style>

  <section class="hero">
    <h2>Welcome to Your Happy Place</h2>
    <p>
      Located on Great Abaco Island in the Bahamas, The Abaco Club on Winding Bay is a private sporting club often described by members as an "adult summer camp"—while still being incredibly family-friendly. Many simply call it their "happy place."
    </p>
    <p>
      Surrounded by natural beauty, pristine beaches, and stunning azure waters, what truly sets this destination apart is its peaceful, uncrowded atmosphere.
    </p>
  </section>

  <section class="features">
    <h2 class="features-heading">Why Stay at Cabana 112?</h2>
    <div class="features-grid">
      <div class="feature">
        <span class="icon">🏝</span>
        <h3>Access to an exclusive, private club experience</h3>
        <p>
          Golf, racquets, beach time, and relaxed dining—on grounds that stay private and uncrowded.
          Cabana 112 offers that members-first setting without the feel of a busy high-rise resort.
        </p>
      </div>
      <div class="feature">
        <span class="icon">🏖</span>
        <h3>Beautiful beachfront setting</h3>
        <p>
          Winding Bay’s white-sand crescent is a short stroll away—swim, walk the shore, or read in the shade.
          The water stays calm and clear for much of the year, perfect for snorkeling or a lazy float.
        </p>
      </div>
      <div class="feature">
        <span class="icon">👥</span>
        <h3>Perfect for couples, families, or a relaxing getaway</h3>
        <p>
          Intimate for two, yet comfortable for a small family or close friends. Set your own pace—
          quiet mornings, slow beach afternoons, and evenings that end on your schedule.
        </p>
      </div>
      <div class="feature">
        <span class="icon">✨</span>
        <h3>Managed by The Southworth Group</h3>
        <p>
          Southworth clubs are known for warm hospitality and well-maintained properties.
          Expect clear communication and careful upkeep from booking through checkout.
        </p>
      </div>
    </div>
  </section>

  <section class="access">
    <h2>Access &amp; Exclusivity</h2>
    <p>
      Access to The Abaco Club is typically reserved for members and reciprocal members of other Southworth properties. However, non-members are allowed a one-time visit without a member—making this rental a rare opportunity to experience the club.
    </p>
  </section>

  <hr class="divider" />

  <section class="rates">
    <h2>Rates</h2>
    <p>
      Renting Cabana 112 is the most accessible way to experience The Abaco Club.
    </p>
    <p class="price">$899 – $1100 per night</p>
  </section>
</Base>
