---
import Base from '../../layouts/Base.astro';

const posts = await Astro.glob('./*.md');
const sorted = posts
  .sort((a, b) => new Date(b.frontmatter.date) - new Date(a.frontmatter.date));
---

<Base
  title="Owner's Journal"
  description="Notes from the owner of Cabana 112 at The Abaco Club — renovations, Abaco travel tips, beach life, and what it's really like at Winding Bay."
  canonicalURL="/blog/"
>
  <style>
    .blog-header {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 3rem 1.5rem 2rem;
    }

    .blog-header h1 {
      font-size: 2rem;
      font-weight: 400;
      color: var(--navy);
      margin-bottom: 0.5rem;
      letter-spacing: 0.02em;
    }

    .blog-header p {
      font-family: sans-serif;
      font-size: 0.92rem;
      color: var(--muted);
      line-height: 1.7;
    }

    .post-list {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 0 1.5rem 4rem;
    }

    .post-card {
      border-top: 1px solid var(--border);
      padding: 1.75rem 0;
    }

    .post-card .date {
      font-family: sans-serif;
      font-size: 0.75rem;
      color: var(--muted);
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin-bottom: 0.5rem;
    }

    .post-card h2 {
      font-size: 1.25rem;
      font-weight: 400;
      color: var(--navy);
      margin-bottom: 0.5rem;
      letter-spacing: 0.01em;
    }

    .post-card h2 a { text-decoration: none; color: inherit; }
    .post-card h2 a:hover { color: var(--teal); }

    .post-card p {
      font-family: sans-serif;
      font-size: 0.88rem;
      color: var(--muted);
      line-height: 1.7;
      margin-bottom: 0.75rem;
    }

    .post-card .read-more {
      font-family: sans-serif;
      font-size: 0.82rem;
      color: var(--teal);
      text-decoration: none;
      letter-spacing: 0.04em;
    }

    .post-card .read-more:hover { color: var(--navy); }
  </style>

  <div class="blog-header">
    <h1>Owner's Journal</h1>
    <p>
      Notes on renovating, visiting, and living with Cabana 112 at
      <a href="https://theabacoclub.com/rentals/cabana-112/" target="_blank" rel="noopener">The Abaco Club on Winding Bay</a>.
    </p>
  </div>

  <div class="post-list">
    {sorted.map(post => (
      <div class="post-card">
        <p class="date">
          {new Date(post.frontmatter.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </p>
        <h2>
          <a href={`/blog/${post.frontmatter.slug}/`}>{post.frontmatter.title}</a>
        </h2>
        <p>{post.frontmatter.description}</p>
        <a href={`/blog/${post.frontmatter.slug}/`} class="read-more">Read more →</a>
      </div>
    ))}
  </div>
</Base>
