---
import Base from './Base.astro';

const { frontmatter } = Astro.props;
const listingURL = 'https://theabacoclub.com/rentals/cabana-112/';

const structuredData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": frontmatter.title,
  "description": frontmatter.description,
  "datePublished": frontmatter.date,
  "author": {
    "@type": "Person",
    "name": frontmatter.author || "Cabana 112 Owner"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Cabana 112 at The Abaco Club",
    "url": "https://cabana112abaco.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://cabana112abaco.com/blog/${frontmatter.slug}/`
  },
  "about": {
    "@type": "LodgingBusiness",
    "name": "Cabana 112 at The Abaco Club",
    "url": listingURL
  }
};
---

<Base
  title={frontmatter.title}
  description={frontmatter.description}
  canonicalURL={`/blog/${frontmatter.slug}/`}
  structuredData={structuredData}
>
  <style>
    .post-header {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 3rem 1.5rem 1.5rem;
    }

    .post-header .breadcrumb {
      font-family: sans-serif;
      font-size: 0.8rem;
      color: var(--muted);
      margin-bottom: 1rem;
    }

    .post-header .breadcrumb a { color: var(--muted); }

    .post-header h1 {
      font-size: clamp(1.6rem, 4vw, 2.4rem);
      font-weight: 400;
      line-height: 1.25;
      color: var(--navy);
      margin-bottom: 0.75rem;
      letter-spacing: 0.01em;
    }

    .post-header .post-meta {
      font-family: sans-serif;
      font-size: 0.8rem;
      color: var(--muted);
      letter-spacing: 0.05em;
    }

    .post-body {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 1.5rem 1.5rem 4rem;
      font-size: 1rem;
      line-height: 1.85;
    }

    .post-body :global(p) { margin-bottom: 1.25rem; }

    .post-body :global(h2) {
      font-size: 1.4rem;
      font-weight: 400;
      color: var(--navy);
      margin: 2.5rem 0 0.75rem;
      letter-spacing: 0.02em;
    }

    .post-body :global(h3) {
      font-size: 1.1rem;
      font-weight: 400;
      color: var(--navy);
      margin: 1.75rem 0 0.5rem;
    }

    .post-body :global(ul), .post-body :global(ol) {
      padding-left: 1.5rem;
      margin-bottom: 1.25rem;
    }

    .post-body :global(li) { margin-bottom: 0.4rem; }

    .post-body :global(blockquote) {
      border-left: 3px solid var(--coral);
      margin: 2rem 0;
      padding: 0.75rem 1.25rem;
      color: var(--muted);
      font-style: italic;
    }

    .listing-cta {
      background: var(--navy);
      color: #fff;
      margin: 2.5rem 0;
      padding: 1.75rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .listing-cta p {
      margin: 0;
      font-family: sans-serif;
      font-size: 0.9rem;
      color: rgba(255,255,255,0.8);
      max-width: 480px;
    }

    .listing-cta a {
      display: inline-block;
      background: var(--coral);
      color: #fff;
      text-decoration: none;
      padding: 0.65rem 1.5rem;
      font-family: sans-serif;
      font-size: 0.82rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      flex-shrink: 0;
    }

    .listing-cta a:hover { background: #e0705f; color: #fff; }

    .back-link {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 2rem 1.5rem 0;
      font-family: sans-serif;
      font-size: 0.85rem;
    }
  </style>

  <div class="post-header">
    <p class="breadcrumb">
      <a href="/">Home</a> / <a href="/blog/">Journal</a> / {frontmatter.title}
    </p>
    <h1>{frontmatter.title}</h1>
    <p class="post-meta">
      {new Date(frontmatter.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      {frontmatter.author ? ` · ${frontmatter.author}` : ''}
    </p>
  </div>

  <article class="post-body">
    <slot />

    <div class="listing-cta">
      <p>
        Cabana 112 is available to rent through The Abaco Club on Winding Bay.
        Check current availability and rates on the official listing page.
      </p>
      <a href={listingURL} target="_blank" rel="noopener">
        View Cabana 112 →
      </a>
    </div>
  </article>

  <div class="back-link">
    <a href="/blog/">← Back to Journal</a>
  </div>
</Base>
